{
	"name": "anon-pi",
	"version": "0.0.0",
	"description": "Launch pi inside a tooljail: anonymized web egress through a socks5h proxy, one direct hole for a local model, seeded pi config on the host.",
	"license": "AGPL-3.0-only",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"anon-pi": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"engines": {
		"node": ">=20"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^25.2.0",
		"as-soon": "^0.1.5",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsc",
		"dev": "as-soon -w src pnpm build",
		"test": "vitest run",
		"test:watch": "vitest"
	}
}
