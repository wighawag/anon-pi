{
	"name": "anon-pi",
	"version": "0.23.0",
	"description": "Launch pi inside a netcage: anonymized web egress through a socks5h proxy, one direct hole for a local model, seeded pi config on the host.",
	"license": "AGPL-3.0-only",
	"keywords": [
		"pi",
		"netcage",
		"anonymity",
		"socks5h",
		"tor",
		"proxy",
		"privacy",
		"cli",
		"agent"
	],
	"homepage": "https://github.com/wighawag/anon-pi#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wighawag/anon-pi.git",
		"directory": "packages/anon-pi"
	},
	"bugs": {
		"url": "https://github.com/wighawag/anon-pi/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"anon-pi": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src",
		"LICENSE",
		"Dockerfile.pi",
		"examples"
	],
	"engines": {
		"node": ">=20"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^25.2.0",
		"as-soon": "^0.1.5",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"copy-readme": "node -e \"require('fs').copyFileSync(require('path').join('..','..','README.md'),'README.md')\"",
		"prepack": "pnpm copy-readme",
		"build": "pnpm copy-readme && tsc",
		"dev": "as-soon -w src pnpm build",
		"test": "pnpm copy-readme && vitest run",
		"test:watch": "vitest"
	}
}
